# Cloudflare full-control API (小 QQ account) — copy to .env.cloudflare (gitignored)
# Docs: docs/environment.md
# Canonical offline copy: ~/.config/boxai/cf-xiaoqq-full.env
#
# Account: 123592844@qq.com's Account
# Token name: xiaoqq-full-control
# Scope: all account perms on this account + all zone perms on you-box.com + R2 buckets

export CLOUDFLARE_ACCOUNT_ID=4379d21a3d3eadc0e37d63abff091f31
export CLOUDFLARE_ZONE_ID=2a653c5c030f278f165adc1cd803adfd
export CLOUDFLARE_ZONE_NAME=you-box.com
export CLOUDFLARE_API_TOKEN=

# --- Playground object storage (R2 bucket: boxai-playground) ---
# S3 token name: boxai-playground-s3 (scoped to this bucket, Object Read+Write)
# R2_ACCESS_KEY_ID = R2 token id; R2_SECRET_ACCESS_KEY = sha256(token value)
export STORAGE_BACKEND=r2
export R2_BUCKET=boxai-playground
export R2_ENDPOINT=https://4379d21a3d3eadc0e37d63abff091f31.r2.cloudflarestorage.com
export R2_ACCESS_KEY_ID=
export R2_SECRET_ACCESS_KEY=
export R2_PUBLIC_BASE_URL=https://assets.you-box.com
export R2_PRESIGN_TTL=600
